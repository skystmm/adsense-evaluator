# AdSense Evaluator 环境变量配置示例
# 复制此文件为 .env 并填入实际值

# ==================== 后端配置 ====================

# JWT 签名密钥（生产环境务必修改！）
# 生成方法：python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-secret-key-change-in-production

# OpenAI API 密钥（用于 AI 建议生成，可选）
OPENAI_API_KEY=sk-your-openai-api-key

# 数据库连接字符串
# SQLite（默认）: sqlite:///./adsense_evaluator.db
# PostgreSQL: postgresql://user:password@localhost:5432/adsense_evaluator
DATABASE_URL=sqlite:///./adsense_evaluator.db

# Token 过期时间（分钟）
ACCESS_TOKEN_EXPIRE_MINUTES=30

# 服务端口
PORT=8000

# ==================== 前端配置 ====================

# 后端 API 地址（前端需要）
# 本地开发：http://localhost:8000
# 生产环境：https://your-backend-domain.com
NEXT_PUBLIC_API_URL=http://localhost:8000

# ==================== Docker Compose 配置 ====================

# 后端 API 地址（Docker 网络内部）
# 如果使用 Docker Compose 部署，前端应该使用这个地址
# NEXT_PUBLIC_API_URL=http://backend:8000
